#!/bin/bash
# ============================================================
# 一键安装入口脚本
# 用法:
#   wget https://raw.githubusercontent.com/SHUI269/Mini_tool/main/install -O myinstaller && . myinstaller
# ============================================================

# 配置
URL_PREFIX="https://raw.githubusercontent.com/SHUI269/Mini_tool/main/"
INSTALL_DIR="/tmp/myinstall"

# 创建临时目录
mkdir -p $INSTALL_DIR/tools

echo "========================================"
echo "  欢迎使用一键安装工具"
echo "========================================"
echo ""

# 下载主程序
echo "[1/2] 下载安装程序..."
wget -q --show-progress $URL_PREFIX/install.py -O $INSTALL_DIR/install.py

# 检查 Python3
echo "[2/2] 检查环境..."
if ! command -v python3 &> /dev/null; then
    echo "错误: 未找到 python3"
    exit 1
fi

# 安装必要依赖（可选，如果系统已有则跳过）
sudo apt-get install -y -qq python3-distro 2>/dev/null || true

# 运行主程序
echo ""
echo "启动安装程序..."
echo ""
sudo python3 $INSTALL_DIR/install.py

# 清理
rm -rf $INSTALL_DIR
rm -f myinstaller 2>/dev/null || true

# 重新加载 shell 配置
if [ -f ~/.bashrc ]; then source ~/.bashrc; fi
if [ -f ~/.zshrc ]; then source ~/.zshrc; fi
