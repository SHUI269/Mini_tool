#!/bin/bash
# ============================================================
# 一键安装入口脚本
# 用法:
#   wget https://raw.githubusercontent.com/SHUI269/Mini_tool/main/install -O myinstaller && . myinstaller
# ============================================================

set -e

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 基础URL
BASE_URL="https://raw.githubusercontent.com/SHUI269/Mini_tool/main"
INSTALL_DIR="/tmp/myinstall_$(date +%s)"
TOOLS_DIR="$INSTALL_DIR/tools"

echo -e "${BLUE}========================================${NC}"
echo -e "${GREEN}  欢迎使用一键安装工具${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# 创建临时目录
rm -rf $INSTALL_DIR
mkdir -p $TOOLS_DIR

# 检查依赖
echo -e "${YELLOW}[1/3] 检查系统依赖...${NC}"
if ! command -v python3 &> /dev/null; then
    echo -e "${RED}错误: 未找到 python3，请先安装${NC}"
    exit 1
fi

# 安装Python依赖
echo -e "${YELLOW}[2/3] 准备运行环境...${NC}"
sudo apt-get update -qq -o Acquire::cdrom::AutoDetect=false 2>/dev/null || true
sudo apt-get install -y -qq -o Acquire::cdrom::AutoDetect=false python3-distro python3-yaml curl wget 2>/dev/null || true

# 下载核心文件
echo -e "${YELLOW}[3/3] 下载安装工具...${NC}"
echo ""

# 下载函数（带进度显示）
download_file() {
    local url="$1"
    local output="$2"
    local name="$3"
    
    echo -e "${CYAN}  ↓ 正在下载: ${name}${NC}"
    echo -e "${CYAN}     URL: ${url}${NC}"
    
    if wget -q --show-progress "$url" -O "$output" 2>&1; then
        local size=$(du -h "$output" 2>/dev/null | cut -f1)
        echo -e "${GREEN}  ✓ 下载成功: ${name} (${size})${NC}"
        echo ""
        return 0
    else
        echo -e "${RED}  ✗ 下载失败: ${name}${NC}"
        echo ""
        return 1
    fi
}

# 下载基础模块
echo -e "${BLUE}>>> 下载基础模块${NC}"
download_file "$BASE_URL/tools/base.py" "$TOOLS_DIR/base.py" "base.py (基础工具类)"

# 下载主程序
echo -e "${BLUE}>>> 下载主程序${NC}"
download_file "$BASE_URL/install.py" "$INSTALL_DIR/install.py" "install.py (主程序)"

# 下载工具模块
echo -e "${BLUE}>>> 下载功能模块${NC}"
TOOLS=("tool_install_ros.py" "tool_config_source.py" "tool_install_docker.py")

for tool in "${TOOLS[@]}"; do
    download_file "$BASE_URL/tools/$tool" "$TOOLS_DIR/$tool" "$tool" || true
done

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}  下载完成，启动安装程序...${NC}"
echo -e "${GREEN}========================================${NC}"
echo ""

# 运行主程序
cd $INSTALL_DIR
sudo python3 install.py

# 清理
rm -rf $INSTALL_DIR
rm -f myinstaller 2>/dev/null || true

echo ""
echo -e "${GREEN}安装程序已退出${NC}"
